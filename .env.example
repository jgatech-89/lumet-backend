# ─── Django ─────────────────────────────────────────────────────────────────
DEBUG=1
SECRET_KEY=changeme-in-production

# Hosts permitidos (separados por coma). Vacío = permitir todos (*).
# ALLOWED_HOSTS=localhost,127.0.0.1,.tudominio.com

# ─── Base de datos ─────────────────────────────────────────────────────────
DB_NAME=lumet_db
DB_USER=lumet_user
DB_PASSWORD=lumet_pass
DB_HOST=localhost
DB_PORT=5432

# ─── Email ─────────────────────────────────────────────────────────────────
# Remitente por defecto (desde dónde se envían correos)
DEFAULT_FROM_EMAIL=noreply@lumet.local

# Resend (producción): API key. Si está definida, el envío usa Resend.
# API_KEY_RESEND=re_xxxx
# Remitente para Resend (debe ser correo/dominio verificado en Resend)
# RESEND_FROM_EMAIL=Lumet <noreply@tudominio.com>
# Remitente cuando el dominio no está verificado (.local, etc.)
# RESEND_SANDBOX_FROM=Lumet <onboarding@resend.dev>
# Logo en plantillas de correo (URL pública)
# LUMET_LOGO_URL=https://tudominio.com/static/logo-email.png

# SMTP alternativo (si no usas Resend)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.ejemplo.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# ─── Autenticación y códigos OTP ───────────────────────────────────────────
# Tiempo de validez del código OTP de login (segundos). Default 600 (10 min)
# LOGIN_CODE_TIMEOUT=600
# Tiempo de validez del token de recuperación de contraseña (segundos). Default 300 (5 min)
# PWD_RESET_TOKEN_TIMEOUT=300

# Simple JWT
# SIMPLE_JWT_ACCESS_TOKEN_MINUTES=60
# SIMPLE_JWT_REFRESH_TOKEN_DAYS=7

# ─── CORS ──────────────────────────────────────────────────────────────────
# Orígenes permitidos cuando DEBUG=0 (separados por coma)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://app.tudominio.com

# ─── API y documentación ───────────────────────────────────────────────────
# API_PAGE_SIZE=20
# API_TITLE=Lumet API
# API_DESCRIPTION=API REST de Lumet. Autenticación por correo + código y JWT.
# API_VERSION=1.0.0

# ─── Cache ─────────────────────────────────────────────────────────────────
# CACHE_MAX_ENTRIES=1000
