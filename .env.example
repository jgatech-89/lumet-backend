# ─── Django (seguridad y entorno) ───────────────────────────────────────────
SECRET_KEY=tu_secret_key
DEBUG=False
# Hosts permitidos (separados por coma). Vacío = permitir todos (*) en dev.
ALLOWED_HOSTS=18.223.117.138,18.223.117.138.nip.io
# Orígenes confiables para CSRF (separados por coma). Usar HTTPS en producción.
CSRF_TRUSTED_ORIGINS=https://18.223.117.138.nip.io
# Cookies solo por HTTPS (True en producción, False en dev local)
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True

# ─── Base de datos ─────────────────────────────────────────────────────────
DB_NAME=lumet_db
DB_USER=lumet_user
DB_PASSWORD=lumet_pass
DB_HOST=localhost
DB_PORT=5432

# ─── Email ─────────────────────────────────────────────────────────────────
DEFAULT_FROM_EMAIL=noreply@lumet.local
# Resend (producción): API key. Si está definida, el envío usa Resend.
# API_KEY_RESEND=re_xxxx
# RESEND_FROM_EMAIL=Lumet <noreply@tudominio.com>
# RESEND_SANDBOX_FROM=Lumet <onboarding@resend.dev>
# LUMET_LOGO_URL=https://tudominio.com/static/logo-email.png
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ─── Autenticación y códigos OTP ───────────────────────────────────────────
# LOGIN_CODE_TIMEOUT=600
# PWD_RESET_TOKEN_TIMEOUT=300
# SIMPLE_JWT_ACCESS_TOKEN_HOURS=10
# SIMPLE_JWT_REFRESH_TOKEN_DAYS=7

# ─── CORS ──────────────────────────────────────────────────────────────────
# Orígenes permitidos cuando DEBUG=0 (separados por coma)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://app.tudominio.com

# ─── API y documentación ───────────────────────────────────────────────────
# API_PAGE_SIZE=20
# API_TITLE=Lumet API
# API_DESCRIPTION=API REST de Lumet. Autenticación por correo + código y JWT.
# API_VERSION=1.0.0

# ─── Cache ─────────────────────────────────────────────────────────────────
# CACHE_MAX_ENTRIES=1000
